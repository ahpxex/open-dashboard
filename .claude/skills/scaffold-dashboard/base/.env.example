# All of these are OPTIONAL for local development. With no .env the app boots in
# zero-config mode: auth uses better-auth's in-memory adapter and resources use
# the in-memory data provider, so `bun dev` works with no Postgres/Docker.
# Set DATABASE_URL to switch the whole stack onto Postgres + Drizzle + better-auth.

# Postgres connection string (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/open_dashboard"

# better-auth: generate a strong secret with `openssl rand -base64 32`
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL exposed to the browser auth client
VITE_BETTER_AUTH_URL="http://localhost:3000"
